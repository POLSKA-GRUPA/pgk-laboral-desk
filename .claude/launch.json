{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Flask dev",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["app.py", "--host", "127.0.0.1", "--port", "8765", "--debug"],
      "port": 8765
    },
    {
      "name": "Gunicorn",
      "runtimeExecutable": "gunicorn",
      "runtimeArgs": ["app:app", "--bind", "127.0.0.1:8766", "--workers", "2", "--reload"],
      "port": 8766
    }
  ]
}
